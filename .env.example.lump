# ==========================================
# TW AutoTrader 環境設定檔
# 單筆 50 萬元 / 8 檔分散 / 中高風險
# ==========================================

# FinMind 設定（ finmind.github.io 註冊免費取得）
FINMIND_API_TOKEN=your_finmind_api_token_here

# 券商選擇（kgi / esun）
BROKER=kgi

# 凱基 API 設定
KGI_API_KEY=your_kgi_api_key_here
KGI_API_SECRET=your_kgi_api_secret_here
USE_REAL_API=false      # true = 真實下單

# 玉山 API 設定（BROKER=esun 時使用）
# ESUN_ACCOUNT_PASSWORD=your_password
# ESUN_CERT_PASSWORD=your_password

# Telegram 通知
TELEGRAM_BOT_TOKEN=您的Telegram機器人Token
TELEGRAM_CHAT_ID=您的Telegram聊天群組ID

# LINE Notify（選擇性）
#LINE_NOTIFY_TOKEN=您的LineNotify權杖密碼

# ==========================================
# 資金配置
# ==========================================
TOTAL_CAPITAL=500000            # 可動用總資金
INITIAL_CAPITAL=500000          # 風險計算用初始資金

# DCA 模式設定（0 = 一筆資金 Lumpsum，>0 = 每月定期定額 DCA）
DCA_AMOUNT=0
ALLOC_BOLLINGER=35              # 布林通道反轉 35% → NT$175,000（0050/006208/00878）
ALLOC_VWAP=20                   # VWAP 偏離反轉 20% → NT$100,000（2881/2886）
ALLOC_MA_CROSS=15               # 均線交叉 15% → NT$75,000（2330）
ALLOC_BREAKOUT=15               # 唐奇安突破 15% → NT$75,000（2382）
ALLOC_KEEP_WAIT=15              # DCA 低接 15% → NT$75,000（2454）

# ==========================================
# 多股組合配置
# ==========================================
PORTFOLIO=0050:bollinger,006208:bollinger,00878:bollinger,2330:ma_cross,2454:keep_wait,2881:vwap,2886:vwap,2382:breakout

# ==========================================
# 風險控管
# ==========================================
MAX_RISK_PER_TRADE=0.02         # 單筆最大風險 2%
MAX_DAILY_LOSS=0.03             # 每日最大虧損 3%
MAX_DAILY_TRADES=5              # 每日最大交易次數
CAPITAL_CONTROL_LINE=30         # 剩餘資金低於此 % 才開始限制交易次數（30 = 剩 30% 以下才限）
MARKET_TREND_FILTER=true        # 大盤年線過濾

# ==========================================
# 下單股數設定
# 金額制（bollinger / vwap / ma_cross）
# ==========================================

# ==========================================
# 每月預算（0 = 不限制）
# 此設定僅用於控管每月花費上限
# ==========================================
MONTHLY_BUDGET_BOLLINGER=0
MONTHLY_BUDGET_VWAP=0
MONTHLY_BUDGET_MA_CROSS=0
MONTHLY_BUDGET_BREAKOUT=0

# ==========================================
# 金字塔加碼（Bollinger 分批進場）
# ==========================================
PYRAMID_ENABLED=true
PYRAMID_TIER1_SHARES=1000
PYRAMID_TIER2_SHARES=2000
PYRAMID_TIER3_SHARES=3000
PYRAMID_TIER2_DROP=0.03
PYRAMID_TIER3_DROP=0.05

# ==========================================
# keep_wait DCA 低接策略（2454 聯發科衛星持股）
# 初始 45 股，跌 5% 加碼 45 股，漲 15% 賣一半
# ==========================================
KW_INITIAL_SHARES=45             # 45 股 × 1,610 ≈ 72,000（初始進場）
KW_ADD_DROP_PCT=5                # 跌 5% 加碼（約 1,530）
KW_ADD_SHARES=45                 # 每次 +45 股
KW_MAX_ADDITIONS=2               # 最多加 2 次（共 135 股）
KW_TP_TRIGGER_PCT=15             # 漲 15% 觸發（約 1,850）
KW_TP_SELL_RATIO=50              # 觸發時賣一半
KW_COOLDOWN_DAYS=30              # 賣出後冷卻 30 天

# ==========================================
# Group 2 — 法人抬轎動能策略（獨立資金池）
# 週五盤後篩選 → 週一開盤進場 → 每日監控停損停利
# 資金來自 INST_MOM_CAPITAL，不佔用 Group 1 配置
# 0 = 不啟用
# ==========================================
INST_MOM_CAPITAL=500000          # 法人抬轎動能 獨立本金（動態選股 3 檔）
INST_MOM_MIN_VOLUME=2000         # 最小近 5 日平均成交量（張）
INST_MOM_BUY_RATIO=0.03          # 投信+外援買超佔總成交量門檻（3%）
INST_MOM_LOOKBACK=20             # 創新高天數
INST_MOM_TOP_N=3                 # 持有標的數量
INST_MOM_STOP_LOSS=0.07          # 硬性停損 -7%
INST_MOM_TRAILING_PERIOD=10      # 移動停利 MA10
INST_MOM_EXCLUDE_ETF=true           # 排除 ETF（true/false）
# ── 篩選頻率 ────────────────────────────
INST_MOM_DAILY_SCREENING=true       # true=每日篩選隔日進場, false=每週五篩選週一進場
# ── 魚過濾（每日篩選：法人低吃 → 動能進場）──
INST_MOM_FISH_FILTER=true           # 啟用魚過濾（true/false）
INST_MOM_FISH_DAYS=90               # 魚過濾回溯天數
INST_MOM_FISH_MIN_SCORE=7.0         # 魚過濾最低分數門檻
# ── 全市場動能搜索排名（市值排序，前 N 大）──
STOCK_NO=150                        # 法人動能搜索排名（預設 150，可調至 50~300）
# ── 獲利滾入 ────────────────────────────
INST_MOM_PROFIT_ROLL_MONTHS=0    # M=0: 每筆獲利都滾入；M>0: 每 M 個月滾一次
INST_MOM_PROFIT_ROLL_PCT=1.0     # 滾入比例（0.0~1.0，1.0=100%）
# ── 停損禁入 ────────────────────────────
INST_MOM_LOSER_BAN_DAYS=0        # 停損禁入天數（0=不啟用）

# ==========================================
# 策略參數（不設定則使用預設值）
# ==========================================
BOLLINGER_WINDOW=20
BOLLINGER_STD_DEV=2.0
BOLLINGER_RSI_PERIOD=5
VWAP_SIGMA_MULT=1.5
VWAP_RSI_PERIOD=5
MA_CROSS_FAST_PERIOD=9
MA_CROSS_SLOW_PERIOD=21
MA_CROSS_ATR_THRESHOLD=0.005
BREAKOUT_LOOKBACK=20
BREAKOUT_ATR_PERIOD=14
BREAKOUT_ATR_THRESHOLD=0.01

# ==========================================
# 內部設定（請勿修改）
# ==========================================
GIT_PAGE=off
